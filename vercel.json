{
  "version": 2,
  "buildCommand": "pnpm --filter client build",
  "outputDirectory": "client/dist",
  "rewrites": [
    {
      "source": "/api/:match*",
      "destination": "https://e-bddk.com/api/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
